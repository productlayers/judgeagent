# Local setup (do not commit secrets):
#   cp .env.example .env
#   cp .env.example .env.local   # for the Next.js CopilotKit UI in app/
#
# --- LLM provider configuration ---
# Which provider the judge uses for rubric derivation + evaluation.
# Options: "openai" (default) or "anthropic".
JUDGE_LLM_PROVIDER=openai

# Model name. Defaults are picked per-provider if left unset:
#   openai    -> gpt-4o-mini
#   anthropic -> claude-3-5-sonnet-latest
JUDGE_MODEL=

# API keys (only the one matching JUDGE_LLM_PROVIDER is required).
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- CopilotKit UI ---
# Used by the Next.js LLM Judge workbench in app/.
# Defaults to openai/gpt-4.1-mini if unset.
COPILOTKIT_MODEL=openai/gpt-4.1-mini

# --- W&B Weave tracing (optional but recommended) ---
# Set both vars to send judge traces to Weave. Without WANDB_API_KEY, tracing
# is skipped (judge still runs). Traces appear at:
#   https://wandb.ai/<your-entity>/<WEAVE_PROJECT>/weave
# Weave records runs; OPENAI_API_KEY (above) is still required for real judging.
WANDB_API_KEY=
WEAVE_PROJECT=agent-judge

# --- Judge behavior ---
# Number of independent judge runs to majority-vote over (consensus mode).
# 1 = single pass (default, fastest). >1 enables consensus.
JUDGE_CONSENSUS_RUNS=1
